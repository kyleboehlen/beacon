### Rules - Hydrate default RulesConfig
GET {{baseUrl}}/api/Rules/HydrateRulesConfig/
Accept: application/json

> {%
    client.test("Request executed successfully", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });

    client.test("Response has success field", function() {
        client.assert(response.body.hasOwnProperty("success"), "Response missing 'success' field");
        client.assert(response.body.success === true, "Success should be true");
    });

    client.test("Response has default rules config", function() {
        client.assert(response.body.hasOwnProperty("payload"), "Response missing 'payload' field");
        client.assert(response.body.payload.hasOwnProperty("defaultRulesConfig"), "Payload missing 'defaultRulesConfig' field");
    });

    client.test("Default rules config has rule options", function() {
        var rulesConfig = response.body.payload.defaultRulesConfig;
        client.assert(rulesConfig.hasOwnProperty("msPipelines"), "Missing 'msPipelines' rule");
        client.assert(rulesConfig.hasOwnProperty("fighters"), "Missing 'fighters' rule");
        client.assert(rulesConfig.hasOwnProperty("cloaking"), "Missing 'cloaking' rule");
        client.assert(rulesConfig.hasOwnProperty("shipGroupLimits"), "Missing 'shipGroupLimits' rule");
        client.assert(rulesConfig.hasOwnProperty("replicators"), "Missing 'replicators' rule");
    });

    client.test("Rule options have required properties", function() {
        var rulesConfig = response.body.payload.defaultRulesConfig;
        var firstRule = rulesConfig.msPipelines;

        client.assert(firstRule.hasOwnProperty("value"), "Rule missing 'value' property");
        client.assert(firstRule.hasOwnProperty("description"), "Rule missing 'description' property");
        client.assert(firstRule.hasOwnProperty("category"), "Rule missing 'category' property");
        client.assert(firstRule.hasOwnProperty("enabled"), "Rule missing 'enabled' property");
        client.assert(firstRule.hasOwnProperty("referenceNumber"), "Rule missing 'referenceNumber' property");
        client.assert(firstRule.hasOwnProperty("rulePage"), "Rule missing 'rulePage' property");
    });

    client.test("RulesConfig has status field", function() {
        var rulesConfig = response.body.payload.defaultRulesConfig;
        client.assert(rulesConfig.hasOwnProperty("status"), "Missing 'status' field");
        client.assert(rulesConfig.status === 0, "Default status should be Draft (0)");
    });
%}

### Rules - Create RulesConfig
POST {{baseUrl}}/api/Rules/CreateRulesConfig
Content-Type: application/json

{
  "rulesConfig": {
    "id": "",
    "status": 0,
    "createdAt": "2025-01-01T00:00:00Z",
    "updatedAt": "2025-01-01T00:00:00Z",
    "msPipelines": { "value": true },
    "defenseSatelliteNetworks": { "value": false },
    "fighters": { "value": true },
    "cloaking": { "value": false },
    "mines": { "value": false },
    "nonPlayerAliens": { "value": false },
    "boardingShips": { "value": false },
    "securityForces": { "value": false },
    "groundCombat": { "value": false },
    "titans": { "value": false },
    "flagships": { "value": false },
    "shipGroupLimits": { "value": true },
    "replicators": { "value": false },
    "instantUpgrades": { "value": false },
    "terraformingNebulae": { "value": false }
  }
}

> {%
    client.test("Request executed successfully", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });

    client.test("Response has success field", function() {
        client.assert(response.body.success === true, "Success should be true");
    });

    client.test("Response has created rules config with ID", function() {
        var rulesConfig = response.body.payload.rulesConfig;
        client.assert(rulesConfig.hasOwnProperty("id"), "RulesConfig missing 'id'");
        client.assert(rulesConfig.id.length > 0, "RulesConfig id should not be empty");
        client.global.set("createdRulesConfigId", rulesConfig.id);
    });
%}

### Rules - Get RulesConfig by ID
GET {{baseUrl}}/api/Rules/GetRulesConfig/{{createdRulesConfigId}}
Accept: application/json

> {%
    client.test("Request executed successfully", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });

    client.test("Response has success field", function() {
        client.assert(response.body.success === true, "Success should be true");
    });

    client.test("Response has rules config with correct ID", function() {
        var rulesConfig = response.body.payload.rulesConfig;
        client.assert(rulesConfig.hasOwnProperty("id"), "RulesConfig missing 'id'");
        client.assert(rulesConfig.id === client.global.get("createdRulesConfigId"), "IDs should match");
    });

    client.test("Loaded config has static fields restored from defaults", function() {
        var rule = response.body.payload.rulesConfig.msPipelines;
        client.assert(rule.description.length > 0, "Description should be restored from defaults");
        client.assert(rule.referenceNumber.length > 0, "ReferenceNumber should be restored from defaults");
        client.assert(rule.rulePage > 0, "RulePage should be restored from defaults");
    });
%}

### Rules - Update RulesConfig
PUT {{baseUrl}}/api/Rules/UpdateRulesConfig/{{createdRulesConfigId}}
Content-Type: application/json

{
  "rulesConfig": {
    "id": "{{createdRulesConfigId}}",
    "status": 0,
    "createdAt": "2025-01-01T00:00:00Z",
    "updatedAt": "2025-01-01T00:00:00Z",
    "msPipelines": { "value": false },
    "defenseSatelliteNetworks": { "value": true },
    "fighters": { "value": true },
    "cloaking": { "value": false },
    "mines": { "value": false },
    "nonPlayerAliens": { "value": false },
    "boardingShips": { "value": false },
    "securityForces": { "value": false },
    "groundCombat": { "value": false },
    "titans": { "value": false },
    "flagships": { "value": false },
    "shipGroupLimits": { "value": true },
    "replicators": { "value": false },
    "instantUpgrades": { "value": false },
    "terraformingNebulae": { "value": false }
  }
}

> {%
    client.test("Request executed successfully", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });

    client.test("Response has success field", function() {
        client.assert(response.body.success === true, "Success should be true");
    });

    client.test("Response has updated rules config", function() {
        var rulesConfig = response.body.payload.rulesConfig;
        client.assert(rulesConfig.msPipelines.value === false, "msPipelines should be false after update");
        client.assert(rulesConfig.defenseSatelliteNetworks.value === true, "defenseSatelliteNetworks should be true after update");
    });
%}

### Rules - Delete RulesConfig
DELETE {{baseUrl}}/api/Rules/DeleteRulesConfig/{{createdRulesConfigId}}
Accept: application/json

> {%
    client.test("Request executed successfully", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });

    client.test("Response has success field", function() {
        client.assert(response.body.success === true, "Success should be true");
    });

